<Window x:Class="BloggerMdViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Blogger Markdown 查看器"
        Height="760"
        Width="1280"
        MinHeight="560"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        AllowDrop="True"
        PreviewDragEnter="Window_DragEnter"
        PreviewDragOver="Window_DragEnter"
        PreviewDrop="Window_Drop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 文档工具栏 -->
        <Border Grid.Row="0"
                Background="{StaticResource ToolbarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="OpenFileButton"
                            Content="打开文件"
                            Click="OpenFileButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="22,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="DocumentTitleText"
                               Text="尚未打开文档"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="DocumentStatusText"
                               Text="选择 Markdown 文件或直接拖入 .md 文件"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Style="{StaticResource SoftPillStyle}">
                    <TextBlock Text="WPF + WebView2"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- 主工作区 -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FileListColumn" Width="280"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 文件列表区域 -->
            <Border x:Name="HistoryPanel"
                    Grid.Column="0"
                    Style="{StaticResource SidePanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="16,16,16,10">
                        <TextBlock Text="打开历史"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="HistoryStatusText"
                                   Text="打开过的 Markdown 文档会显示在这里"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ListBox x:Name="HistoryListBox"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource FileListItemStyle}"
                             SelectionChanged="HistoryListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding FileName}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding FilePath}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter x:Name="Splitter"
                          Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- 预览区域 -->
            <Border Grid.Column="2"
                    Style="{StaticResource PreviewPanelStyle}">
                <Grid>
                    <StackPanel x:Name="EmptyStatePanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="360">
                        <TextBlock Text="Markdown 文档查看器"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="点击打开文件，或把 .md 文件拖到窗口任意位置。左侧会记录打开历史。"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                    <wv2:WebView2 x:Name="PreviewWebView"
                                  Visibility="Collapsed"/>
                    <Border x:Name="DropOverlay"
                            Background="#22FFFFFF"
                            AllowDrop="True"
                            Visibility="Collapsed"
                            DragEnter="Window_DragEnter"
                            DragOver="Window_DragEnter"
                            DragLeave="Window_DragLeave"
                            Drop="Window_Drop">
                        <Border Width="360"
                                Padding="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource PrimaryBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock Text="释放以打开 Markdown 文件"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"/>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- 右侧目录区域 -->
            <Border Grid.Column="4"
                    Style="{StaticResource SidePanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="16,16,16,10">
                        <TextBlock Text="目录"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TocStatusText"
                                   Text="打开文档后显示 ## / ### 标题"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ListBox x:Name="TocListBox"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource TocListItemStyle}"
                             SelectionChanged="TocListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}"
                                           FontSize="{Binding FontSize}"
                                           FontWeight="{Binding FontWeight}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="{Binding Indent}"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
